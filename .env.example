# Local Ollama configuration for src/normalizer.py
# Copy this file to .env and adjust if your setup differs.

# Model tag to use for normalization. Must be pulled locally first:
#   ollama pull llama3.1:8b
OLLAMA_MODEL=llama3.1:8b

# Ollama server URL. Default is the local daemon started by `ollama serve`.
OLLAMA_HOST=http://localhost:11434
